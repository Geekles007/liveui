{
  "name": "everstate-core",
  "version": "0.1.0",
  "description": "Headless contract (AsyncState), content hashing, and registry schema/helpers for everstate.",
  "license": "MIT",
  "author": "Geekles007",
  "homepage": "https://geekles007.github.io/everstate",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Geekles007/everstate.git",
    "directory": "packages/core"
  },
  "keywords": ["everstate", "async-state", "registry", "react", "shadcn"],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
